# Backend (Express) — ตั้งค่าเหล่านี้ใน Render → Environment
# (อย่า commit ค่าจริงขึ้น GitHub — ใส่ผ่าน dashboard เท่านั้น)

# MongoDB Atlas connection string (มีอยู่แล้วในเครื่อง)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/?appName=Cluster0

# Render กำหนด PORT ให้เองอัตโนมัติ — ไม่ต้องตั้งก็ได้ (server.js ใช้ process.env.PORT)
PORT=5001

# Email (SMTP) สำหรับ OTP / notification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_NAME=InGreen
SMTP_FROM_EMAIL=your-email@gmail.com

# Demo mode (ทดสอบหลาย user ในเครื่องเดียว) — production ควรเอาออก/ตั้ง false
DEMO_VOTER_IP_FROM_HEADER=true
